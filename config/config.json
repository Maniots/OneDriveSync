{
    "settings": {
        "log_level": "INFO",
        "mirror": true,
        "retry": 0,
        "wait": 0
    },

    "onedrive_root": "%OneDrive%",

    "folders": [
        {
            "name": "AppData Local",
            "cloud": "PCSync/AppData/Local",
            "local": "%LOCALAPPDATA%"
        },
        {
            "name": "AppData Roaming",
            "cloud": "PCSync/AppData/Roaming",
            "local": "%APPDATA%"
        }
    ],

    "exclude_files": [
        "*.tmp",
        "*.log"
    ],

    "exclude_dirs": [
        "Cache",
        "Temp"
    ]
}